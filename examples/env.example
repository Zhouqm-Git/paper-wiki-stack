# Required: MinerU API Management token, not a normal web login token.
MINERU_API_TOKEN=replace_with_mineru_api_token

# Required: Obsidian vault root using the claude-obsidian paper-wiki layout.
VAULT_ROOT=/absolute/path/to/claude-obsidian

# Required: Zotero hybrid/local configuration.
ZOTERO_LOCAL=true
ZOTERO_LIBRARY_ID=replace_with_library_id
ZOTERO_USER_ID=replace_with_user_id
ZOTERO_API_KEY=replace_with_zotero_write_api_key
ZOTERO_LIBRARY_TYPE=user

# Optional: local recommendation JSON produced by zotero-arxiv-daily.
RECOMMENDATIONS_URL=/absolute/path/to/zotero-arxiv-daily/data/recommendations

# Optional: only needed if you use WebDAV as a Zotero file-storage backend.
WEBDAV_URL=
WEBDAV_USER=
WEBDAV_PASS=

# Optional: local embedding/rerank support used by some vault retrieval flows.
OLLAMA_HOST=http://127.0.0.1:11434
