{
  "mcpServers": {
    "zotero": {
      "command": "zotero-mcp",
      "args": [],
      "env": {
        "ZOTERO_LOCAL": "true",
        "ZOTERO_LIBRARY_ID": "replace_with_library_id",
        "ZOTERO_USER_ID": "replace_with_user_id",
        "ZOTERO_API_KEY": "replace_with_zotero_write_api_key",
        "ZOTERO_LIBRARY_TYPE": "user"
      }
    },
    "mineru_zotero": {
      "command": "mineru-zotero-mcp",
      "args": [],
      "env": {
        "MINERU_API_TOKEN": "replace_with_mineru_api_token",
        "VAULT_ROOT": "/absolute/path/to/claude-obsidian",
        "ZOTERO_LOCAL": "true",
        "ZOTERO_LIBRARY_ID": "replace_with_library_id",
        "ZOTERO_USER_ID": "replace_with_user_id",
        "ZOTERO_API_KEY": "replace_with_zotero_write_api_key",
        "ZOTERO_LIBRARY_TYPE": "user",
        "RECOMMENDATIONS_URL": "/absolute/path/to/zotero-arxiv-daily/data/recommendations"
      }
    }
  }
}
